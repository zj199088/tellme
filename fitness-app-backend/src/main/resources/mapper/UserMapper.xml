<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fitness.app.mapper.UserMapper">

    <select id="selectByOpenId" parameterType="java.lang.String" resultType="com.fitness.app.entity.User">
        SELECT * FROM user WHERE open_id = #{openId} AND is_deleted = 0
    </select>

    <select id="selectByUsername" parameterType="java.lang.String" resultType="com.fitness.app.entity.User">
        SELECT * FROM user WHERE username = #{username} AND is_deleted = 0
    </select>

</mapper>